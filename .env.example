# Neon (Vercel integration injects these automatically in production)
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=

# Upstash Redis (standard names; Vercel may use a project prefix instead)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin panel (set a long random value; never commit the real password)
ADMIN_PASSWORD=

# Vercel Blob (add via Vercel Storage > Blob in project settings)
BLOB_READ_WRITE_TOKEN=
