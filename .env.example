# Neon Postgres (Vercel integration injects many of these automatically)
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Vercel may also use project-prefixed Neon names (e.g. AntiPulitzer_DATABASE_URL)

# Upstash Redis (standard names; Vercel may use AntiPulitzer_KV_* instead)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# AntiPulitzer_KV_REST_API_URL=
# AntiPulitzer_KV_REST_API_TOKEN=
# AntiPulitzer_KV_REST_API_READ_ONLY_TOKEN=  (not used by this app)
# AntiPulitzer_KV_URL=                        (not used — REST vars required)
# AntiPulitzer_REDIS_URL=                     (not used — REST vars required)

# Admin panel (set a long random value; never commit the real password)
ADMIN_PASSWORD=

# Vercel Blob
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=
